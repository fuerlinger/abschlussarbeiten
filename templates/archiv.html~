<h2>Archivierte Aufgabensteller</h2>
<table>
    <tr><th style="width:8%">ID</th><th>Details</th><th style="width:15%">Aktionen</th></tr>
    {% for a in aufgabensteller %}
    <tr><td>{{ a.id }}</td><td>{{ a.name }}, {{ a.email }}, {{ a.web }}</td>
      <td><button class="btn btn-rest" hx-post="/api/dearchive/aufgabensteller/{{ a.id }}" hx-target="closest tr" " >Wiederherstellen</button></td></tr>
    {% else %}
    <tr><td colspan="3">Keine archivierten Aufgabensteller</td></tr>
    {% endfor %}
</table>

<br>

